# Cloudflare Turnstile
TURNSTILE_SITE_KEY=your_cloudflare_turnstile_site_key_here
TURNSTILE_SECRET_KEY=your_cloudflare_turnstile_secret_key_here

# Resend Email API
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxx
# The "from" email must be a verified domain in your Resend account
# For development, you can use onboarding@resend.dev
RESEND_FROM_EMAIL=onboarding@resend.dev
# The destination email to receive contact form submissions
RESEND_TO_EMAIL=your_email@example.com
