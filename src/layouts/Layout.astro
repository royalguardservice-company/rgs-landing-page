---
import logo from '../assets/images/logo.png';
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
	image?: string;
}

const {
	title = 'RGS - บริการรักษาความปลอดภัยและงานทำความสะอาดครบวงจร ระดับมืออาชีพ',
	description = 'บริษัท รักษาความปลอดภัย รอยัลการ์ด เซอร์วิสเซส จำกัด (RGS) บริการรักษาความปลอดภัยและงานทำความสะอาดครบวงจร ด้วยมาตรฐานสากล (SOP, NSRS) ผสานเทคโนโลยีทันสมัย เพื่อความปลอดภัยสูงสุดของคุณ',
	image = logo.src
} = Astro.props;
---

<!DOCTYPE html>
<html lang="th">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href={logo.src} />
		<meta name="description" content={description} />
		<meta name="keywords" content="รักษาความปลอดภัย, รปภ., บริการรักษาความปลอดภัย, ทำความสะอาด, Big Cleaning, รปภ.มืออาชีพ, Security Guard, Cleaning Services, RGS" />
		<meta name="author" content="บริษัท รักษาความปลอดภัย รอยัลการ์ด เซอร์วิสเซส จำกัด" />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:locale" content="th_TH" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={image} />

		<title>{title}</title>

		<!-- Preconnect for fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>


		<!-- Google Analytics - loaded dynamically via CookieConsent -->

			<script is:inline type="application/javascript">
				// Initialize dataLayer for Google Analytics
				window.dataLayer = window.dataLayer || [];

				// Set default consent state (all denied until user accepts)
				window.gtag = window.gtag || function() {
					window.dataLayer.push(arguments);
				};

				// Function to load Google Analytics scripts dynamically
				window.loadGoogleAnalytics = function() {
					// Prevent duplicate loading
					console.log("GA load function called");
					if (window.gaLoaded) {
					  console.log("GA already loaded, skipping");
							return;
					}
					window.gaLoaded = true;

					// Create and inject gtag.js script
					const script = document.createElement('script');
					script.async = true;
					script.src = 'https://www.googletagmanager.com/gtag/js?id=G-YYL97TTE21';
					script.onload = function() {
						// After gtag.js loads, initialize with granted consent
						window.gtag('consent', 'update', {
							ad_storage: 'granted',
							ad_user_data: 'granted',
							ad_personalization: 'granted',
							analytics_storage: 'granted',
						});
						window.gtag('js', new Date());
						window.gtag('config', 'G-YYL97TTE21');
					};
					document.head.appendChild(script);
				};

				// Set default consent (all denied)
				window.gtag('consent', 'default', {
					ad_storage: 'denied',
					ad_user_data: 'denied',
					ad_personalization: 'denied',
					analytics_storage: 'denied',
				});
			</script>


		<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orestbida/cookieconsent@3.1.0/dist/cookieconsent.css">

	</head>

	<body>

		<slot />
		<script is:inline type="module" src="/scripts/cookieconsent-config.js"></script>

	</body>
</html>

<style is:global>
	html {
		scroll-padding-top: 80px;
	}

	/* Focus visible styles */
	:focus-visible {
		outline: 2px solid #e63946;
		outline-offset: 2px;
	}
</style>
