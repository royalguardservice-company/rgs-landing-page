---
import hikivisionLogo from '../assets/images/hikivisionLogo.svg';
import dahuaLogo from '../assets/images/dahuaLogo.svg';
import hipLogo from '../assets/images/hipLogo.png';
import citLogo from '../assets/images/citLogo.webp';
import { Image } from 'astro:assets';
import TechShowcase from './TechShowcase.astro';
import OnboardingTimeline from './why-choose-us/OnboardingTimeline.astro';
import TrainingSection from './why-choose-us/TrainingSection.astro';
import ProfessionalTeam from './why-choose-us/ProfessionalTeam.astro';

// (A) Vision + Mission
const missions = [
	{ icon: 'shield', label: 'ครอบคลุม', title: 'Coverage', description: 'บริการทั่วประเทศ' },
	{ icon: 'award', label: 'มาตรฐาน', title: 'Standard', description: 'SOP & NSRS' },
	{ icon: 'lightbulb', label: 'นวัตกรรม', title: 'Innovation', description: 'เทคโนโลยีทันสมัย' },
	{ icon: 'zap', label: 'รวดเร็ว', title: 'Speed', description: 'พร้อมเข้างานทันที' },
];



const hardwarePartners = [
	{ name: 'Hikvision', image : hikivisionLogo },
	{ name: 'Dahua', image : dahuaLogo },
	{ name: 'HIP', image: hipLogo },
	{ name: 'Easy Pass', image: citLogo }
];
---

<!-- Main Section -->
<section id="why-us" class="bg-navy-950">

	<!-- (A) Vision & Mission - Opening -->
	<div class="container-custom section-padding">
		<div class="grid lg:grid-cols-2 gap-12 items-center">
			<!-- Left Side: Vision -->
			<div class="space-y-6">
				<p class="text-amber-500 font-medium tracking-wide uppercase text-sm">Why Choose RGS</p>
				<h2 class="text-white text-4xl lg:text-5xl font-bold leading-tight">
					มุ่งมั่นยกระดับมาตรฐานรักษาความปลอดภัย
					<br />
					ด้วยนวัตกรรมและบุคลากรมืออาชีพ
				</h2>
				<p class="text-gray-400 text-lg max-w-xl">
					บริการงานระดับมืออาชีพที่หลากหลายและครบวงจรในหนึ่งเดียว
				</p>
			</div>

			<!-- Right Side: Mission Cards -->
			<div class="grid grid-cols-2 gap-4">
				{missions.map((mission) => (
					<div class="group relative">
						<div class="absolute -inset-1 bg-gradient-to-br from-amber-500/20 to-transparent rounded-2xl blur-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
						<div class="relative bg-navy-900/80 backdrop-blur-sm border border-white/10 rounded-2xl p-6 transition-all duration-300 group-hover:border-amber-500/30 group-hover:-translate-y-1">
							<div class="w-12 h-12 mb-4">
								{mission.icon === 'shield' && (
									<svg class="w-full h-full text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
									</svg>
								)}
								{mission.icon === 'award' && (
									<svg class="w-full h-full text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4"/>
									</svg>
								)}
								{mission.icon === 'lightbulb' && (
									<svg class="w-full h-full text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
									</svg>
								)}
								{mission.icon === 'zap' && (
									<svg class="w-full h-full text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>
									</svg>
								)}
							</div>
							<p class="text-amber-500 text-sm font-medium mb-1">{mission.label}</p>
							<h3 class="text-white font-semibold text-lg">{mission.title}</h3>
							<p class="text-gray-500 text-sm mt-1">{mission.description}</p>
						</div>
					</div>
				))}
			</div>
		</div>
	</div>

	<!-- Divider -->
	<div class="h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>

	<!-- (B) Standard & Technology -->
	<div class="container-custom py-20">
		<div class="text-center mb-12">
			<p class="text-blue-400 font-medium tracking-wide uppercase text-sm mb-2">Standard & Technology</p>
			<h2 class="text-3xl font-bold text-white mb-3">มาตรฐานสากล + เทคโนโลยีทันสมัย</h2>
			<p class="text-gray-400 max-w-2xl mx-auto">ระบบความปลอดภัยอัจฉริยะที่ช่วยให้คุณตรวจสอบและมั่นใจได้ตลอด 24 ชั่วโมง</p>
		</div>

		<!-- Tech Showcase - 4 Phone Mockups -->
		<div class="py-12">
			<TechShowcase />
		</div>

		<!-- Hardware Partners - Small Logo Strip -->
		<div class="flex flex-wrap items-center justify-center gap-8 md:gap-12">
			<p class="text-gray-500 text-sm">ใช้งานอุปกรณ์จากแบรนด์ชั้นนำ:</p>
			{hardwarePartners.map((partner) => (
			<div class="text-center">
					<Image
						src={partner.image}
						alt={partner.name}
						width={120}
						height={60}
						class="h-20 w-auto object-contain mx-auto mb-3  "
						format="webp"
					/>
				</div>
			))}
		</div>
	</div>

	<!-- Divider -->
	<div class="h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>

	<!-- (C) Quality Assurance (Training) -->
	<TrainingSection />

	<!-- Divider -->
	<div class="h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>

	<!-- (D) Professional Team -->
	<ProfessionalTeam />

	<!-- Divider -->
	<div class="h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>

	<!-- Timeline (The Closer - Anxiety Reducer) -->
	<div class="container-custom py-20">
		<OnboardingTimeline />
	</div>

</section>
