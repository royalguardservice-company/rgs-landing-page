---
---

<div id="cookie-consent" class="cookie-consent hidden">
	<div class="cookie-consent-content">
		<p class="cookie-text">
			เราใช้คุกกี้เพื่อปรับปรุงไซต์ของเราและประสบการณ์ของคุณ อ่านเพิ่มเติมได้ที่
			<a href="/policy" class="cookie-link">นโยบายความเป็นส่วนตัว</a>
		</p>
		<button id="accept-cookies" class="accept-button">
			ยอมรับ
		</button>
	</div>
</div>

<style>
	.cookie-consent {
		position: fixed;
		bottom: 0;
		left: 0;
		right: 0;
		background-color: #374151;
		color: #ffffff;
		padding: 1rem 1.5rem;
		z-index: 9999;
		box-shadow: 0 -4px 6px -1px rgba(0, 0, 0, 0.1);
		transition: transform 0.3s ease-in-out;
	}

	.cookie-consent.hidden {
		display: none;
	}

	.cookie-consent-content {
		max-width: 1400px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		align-items: flex-start;
	}

	@media (min-width: 640px) {
		.cookie-consent-content {
			flex-direction: row;
			justify-content: space-between;
			align-items: center;
		}
	}

	.cookie-text {
		font-size: 0.875rem;
		line-height: 1.5;
		margin: 0;
		flex: 1;
	}

	.cookie-link {
		color: #fbbf24;
		text-decoration: underline;
		transition: color 0.2s ease;
	}

	.cookie-link:hover {
		color: #f59e0b;
	}

	.accept-button {
		background-color: #fbbf24;
		color: #1f2937;
		border: none;
		padding: 0.5rem 1.5rem;
		border-radius: 0.375rem;
		font-weight: 600;
		font-size: 0.875rem;
		cursor: pointer;
		transition: background-color 0.2s ease, transform 0.1s ease;
		white-space: nowrap;
	}

	.accept-button:hover {
		background-color: #f59e0b;
	}

	.accept-button:active {
		transform: scale(0.98);
	}

	@media (max-width: 639px) {
		.accept-button {
			width: 100%;
		}
	}
</style>

<script>
	// Check if user has already accepted cookies
	const hasAccepted = localStorage.getItem('cookieConsent');
	const cookieBanner = document.getElementById('cookie-consent') as HTMLElement;

	if (!hasAccepted && cookieBanner) {
		// Show banner after a short delay
		setTimeout(() => {
			cookieBanner.classList.remove('hidden');
		}, 500);
	}

	const acceptButton = document.getElementById('accept-cookies') as HTMLButtonElement;

	acceptButton?.addEventListener('click', () => {
		// Store consent in localStorage
		localStorage.setItem('cookieConsent', 'accepted');

		// Hide banner with animation
		if (cookieBanner) {
			cookieBanner.style.transform = 'translateY(100%)';
			setTimeout(() => {
				cookieBanner.classList.add('hidden');
				cookieBanner.style.transform = '';
			}, 300);
		}
	});
</script>
