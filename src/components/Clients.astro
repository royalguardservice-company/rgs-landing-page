---
import { Image } from 'astro:assets';
import aomsinLogo from '../assets/images/aomsinLogo.jpg';
import bangsueLogo from '../assets/images/bangsueLogo.png';
import centralHouseLogo from '../assets/images/centralHouseLogo.png';
import crystalSolanaLogo from '../assets/images/crystalSolanaLogo.jpg';
import edsLogo from '../assets/images/edsLogo.png';
import egatLogo from '../assets/images/egatLogo.png';
import emblemOfTheCrownLogo from '../assets/images/emblemOfTheCrownLogo.png';
import huaweiLogo from '../assets/images/huaweiLogo.png';
import jebsenLogo from '../assets/images/jebsenLogo.png';
import nfiLogo from '../assets/images/nfiLogo.jpg';
import narasiriLogo from '../assets/images/narasiriLogo.png';
import pathumThaniPlaceHotelLogo from '../assets/images/pathumThaniPlaceHotelLogo.jpg';
import pearlResortLogo from '../assets/images/perarlResortLogo.jpg';
import qslLogo from '../assets/images/qslLogo.webp';
import thainaokaLogo from '../assets/images/thainaokaLogo.png';
import thanakornApartmentLogo from '../assets/images/thanakornApartmentLogo.jpg';
import wasugreeLogo from '../assets/images/wasugreeLogo.png';
const featuredClients = [
	{ name: 'ธนาคารออมสิน', logo: aomsinLogo },
	{ name: 'การไฟฟ้าฝ่ายผลิตแห่งประเทศไทย', logo: egatLogo },
	{ name: 'โครงการนาราสิริ สาทร', logo: narasiriLogo },
	{ name: 'Huawei', logo: huaweiLogo },
	{name: "nfi", logo: nfiLogo},
	{name: 'บางซื่อ', logo: bangsueLogo},
	{name: 'บ้านกลางเมือง', logo : centralHouseLogo},
	{name: 'Crystal Solana',  logo : crystalSolanaLogo},
	{name: 'EDS' , logo: edsLogo},
	{name: 'emblemOfTheCrownLogo', logo : emblemOfTheCrownLogo},
	{name: 'jebsenLogo' , logo : jebsenLogo},
	{name: 'pathumThaniPlaceHotelLogo', logo : pathumThaniPlaceHotelLogo},
	{name: 'pearlResortLogo', logo: pearlResortLogo },
	{name : 'qslLogo' , logo: qslLogo},
	{name: 'thainaokaLogo', logo: thainaokaLogo},
	{name: 'thanakornApartmentLogo', logo: thanakornApartmentLogo},
	{name: 'wasugreeLogo', logo : wasugreeLogo}



];

const marqueeClients = [
	{ name: 'บมจ. ออมสิน' }, { name: 'กฟผ.' }, { name: 'CPB' }, { name: 'NFI' }, { name: 'DLTV' },
	{ name: 'ที่พัก 904' }, { name: 'Narasiri' }, { name: 'Crystal Solana' }, { name: 'Urbanion' }, { name: 'S-Sense' },
	{ name: 'Huawei' }, { name: 'Samsung' }, { name: 'True' }, { name: 'Canon' }, { name: 'Sharp' },
	{ name: 'HIP' }, { name: 'Easy Pass' }, { name: 'Covestro' }, { name: 'Thainaoka' }, { name: 'SFS' },
	{ name: 'การปิงนิล' }, { name: 'ไทยออยล์' }, { name: 'ปตท.' }, { name: 'CAT' }, { name: 'AOT' }
];
---

<section id="clients" class="section-padding bg-white">
	<div class="container-custom">
		<!-- Section Header -->
		<div class="text-center mb-16">
			<p class="section-subtitle">ลูกค้าของเรา</p>
			<h2 class="section-title text-navy-950">ไว้วางใจโดยองค์กรชั้นนำ</h2>
			<p class="text-gray-600 max-w-2xl mx-auto mt-4">
				เราภูมิยินดีที่ได้รับความไว้วางใจจากหน่วยงานราชการ รัฐวิสาหกิจ และบริษัทชั้นนำให้เป็นผู้ให้บริการ
			</p>
		</div>

		<!-- Featured Clients (Static Row) -->
		<div class="mb-16">
			<div class="text-center mb-8">
				<span class="inline-flex items-center gap-2 px-4 py-2 bg-blue-100 border border-blue-200 rounded-full">
					<svg class="w-4 h-4 text-blue-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.688-1.538a1 1 0 00-.95-.69H11.07a1 1 0 00-.95.69L7.56 10.306a1 1 0 00-.363-1.118L3.22 6.298c-.783-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
					</svg>
					<span class="text-blue-900 text-sm font-medium">บริษัทชั้นนำที่ไว้ใจเรา</span>
				</span>
			</div>

			<div class="grid grid-cols-2 md:grid-cols-5 gap-6">
				{featuredClients.map((client) => (
					<div class="text-center">
							<Image
								src={client.logo}
								alt={client.name}
								width={120}
								height={60}
								class="h-16 w-auto object-contain mx-auto mb-3 opacity-80 group-hover:opacity-100 transition-opacity"
								format="webp"
							/>
						</div>

				))}
			</div>
		</div>


	</div>
</section>

<style>
	@keyframes marquee {
		0% {
			transform: translateX(0);
		}
		100% {
			transform: translateX(-50%);
		}
	}

	.animate-marquee {
		animation: marquee 30s linear infinite;
	}

	.animate-marquee:hover {
		animation-play-state: paused;
	}
</style>
