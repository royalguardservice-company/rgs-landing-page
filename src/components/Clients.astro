---
import { Image } from 'astro:assets';
import aomsinLogo from '../assets/images/aomsinLogo.jpg';
import bangsueLogo from '../assets/images/bangsueLogo.png';
import centralHouseLogo from '../assets/images/centralHouseLogo.png';
import citLogo from '../assets/images/citLogo.webp';
import covestroLogo from '../assets/images/covestroLogo.png';
import crystalSolanaLogo from '../assets/images/crystalSolanaLogo.jpg';
import dahuaLogo from '../assets/images/dahuaLogo.svg';
import dusitUniLogo from '../assets/images/dusitUniLogo.png';
import edsLogo from '../assets/images/edsLogo.png';
import egatLogo from '../assets/images/egatLogo.png';
import emblemOfTheCrownLogo from '../assets/images/emblemOfTheThaiCrownLogo.png';
import hikivisionLogo from '../assets/images/hikivisionLogo.svg';
import hipLogo from '../assets/images/hipLogo.png';
import huaweiLogo from '../assets/images/huaweiLogo.png';
import indochinaHotelLogo from '../assets/images/indochinaHotelLogo.png';
import indochinaVietnamLogo from '../assets/images/indochinaVietnamLogo.png';
import jebsenLogo from '../assets/images/jebsenLogo.png';
import jetAsiaLogo from '../assets/images/jetAsiaLogo.png';
import log3Logo from '../assets/images/log3Logo.png';
import nfiLogo from '../assets/images/nfiLogo.jpg';
import narasiriLogo from '../assets/images/narasiriLogo.png';
import pathumThaniPlaceHotelLogo from '../assets/images/pathumThaniPlaceHotelLogo.jpg';
import pearlResortLogo from '../assets/images/perarlResortLogo.jpg';
import prachapatLogo from '../assets/images/prachapatLogo.png';
import qslLogo from '../assets/images/qslLogo.webp';
import royalLogo from '../assets/images/royalLogo.png';
import sSenseLogo from '../assets/images/sSenseLogo.png';
import tclLogo from '../assets/images/tclLogo.png';
import thainaokaLogo from '../assets/images/thainaokaLogo.png';
import thanakornApartmentLogo from '../assets/images/thanakornApartmentLogo.jpg';
import wasugreeLogo from '../assets/images/wasugreeLogo.png';

const featuredClients = [
	{ name: 'ธนาคารออมสิน', logo: aomsinLogo },
	{ name: 'การไฟฟ้าฝ่ายผลิตแห่งประเทศไทย', logo: egatLogo },
	{ name: 'โครงการนาราสิริ สาทร', logo: narasiriLogo },
	{ name: 'Huawei', logo: huaweiLogo },
	{ name: 'NFI', logo: nfiLogo },
	{ name: 'บางซื่อ', logo: bangsueLogo },
	{ name: 'บ้านกลางเมือง', logo: centralHouseLogo },
	{ name: 'Crystal Solana', logo: crystalSolanaLogo },
	{ name: 'EDS', logo: edsLogo },
	{ name: 'สถาบันเทคโนโลยีพระจอมเกล้าเจ้าคุณทหารลาดกระบัง', logo: emblemOfTheCrownLogo },
	{ name: 'Jebsen & Jessen', logo: jebsenLogo },
	{ name: 'Pathum Thani Place Hotel', logo: pathumThaniPlaceHotelLogo },
	{ name: 'Pearl Resort', logo: pearlResortLogo },
	{ name: 'QSL Logistics', logo: qslLogo },
	{ name: 'Thainaoka', logo: thainaokaLogo },
	{ name: 'Thanakorn Apartment', logo: thanakornApartmentLogo },
	{ name: 'Wasugree', logo: wasugreeLogo },
	{ name: 'CIT', logo: citLogo },
	{ name: 'Covestro', logo: covestroLogo },
	{ name: 'Dahua', logo: dahuaLogo },
	{ name: 'Dusit University', logo: dusitUniLogo },
	{ name: 'Hikvision', logo: hikivisionLogo },
	{ name: 'HIP', logo: hipLogo },
	{ name: 'Indochina Hotel', logo: indochinaHotelLogo },
	{ name: 'Indochina Vietnam', logo: indochinaVietnamLogo },
	{ name: 'Jet Asia', logo: jetAsiaLogo },
	{ name: 'Log3', logo: log3Logo },
	{ name: 'Prachapat', logo: prachapatLogo },
	{ name: 'Royal Guard Services', logo: royalLogo },
	{ name: 'S-Sense', logo: sSenseLogo },
	{ name: 'TCL', logo: tclLogo },
];

const itemsPerPage = 20;
const totalPages = Math.ceil(featuredClients.length / itemsPerPage);

// Split clients into pages
const clientPages = [];
for (let i = 0; i < featuredClients.length; i += itemsPerPage) {
	clientPages.push(featuredClients.slice(i, i + itemsPerPage));
}
---

<section id="clients" class="section-padding bg-white">
	<div class="container-custom">
		<div class="text-center mb-16">
			<p class="section-subtitle">ลูกค้าของเรา</p>
			<h2 class="section-title text-navy-950">ไว้วางใจโดยองค์กรชั้นนำ</h2>
			<p class="text-gray-600 max-w-2xl mx-auto mt-4">
				เราภูมิยินดีที่ได้รับความไว้วางใจจากหน่วยงานราชการ รัฐวิสาหกิจ และบริษัทชั้นนำให้เป็นผู้ให้บริการ
			</p>
		</div>

		<div class="relative">
			<!-- Left Arrow -->
			<button
				id="prevBtn"
				class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-2 md:-translate-x-4 z-10 bg-white shadow-lg rounded-full p-2 md:p-3 hover:bg-gray-100 transition-all duration-300 disabled:opacity-30 disabled:cursor-not-allowed border border-gray-200"
				aria-label="Previous clients"
			>
				<svg class="w-5 h-5 md:w-6 md:h-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
				</svg>
			</button>

			<!-- Slider Container -->
			<div class="overflow-hidden mx-8 md:mx-12">
				<div
					id="sliderTrack"
					class="flex transition-transform duration-500 ease-in-out"
					style="transform: translateX(0%);"
					data-total-pages={totalPages}
				>
					{clientPages.map((pageClients) => (
						<div class="w-full flex-shrink-0 grid grid-cols-2 md:grid-cols-5 gap-4 md:gap-6 px-2">
							{pageClients.map((client) => (
								<div class="text-center">
									<Image
										src={client.logo}
										alt={client.name}
										width={120}
										height={60}
										class="h-12 md:h-16 w-auto object-contain mx-auto mb-2 md:mb-3 opacity-80 hover:opacity-100 transition-opacity"
										format="webp"
									/>
								</div>
							))}
						</div>
					))}
				</div>
			</div>

			<!-- Right Arrow -->
			<button
				id="nextBtn"
				class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-2 md:translate-x-4 z-10 bg-white shadow-lg rounded-full p-2 md:p-3 hover:bg-gray-100 transition-all duration-300 disabled:opacity-30 disabled:cursor-not-allowed border border-gray-200"
				aria-label="Next clients"
			>
				<svg class="w-5 h-5 md:w-6 md:h-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
				</svg>
			</button>
		</div>

		<!-- Pagination Dots -->
		<div class="flex justify-center gap-2 mt-6 md:mt-8">
			{Array.from({ length: totalPages }, (_, i) => (
				<button
					class:list={['pagination-dot', { active: i === 0 }]}
					data-page={i}
					aria-label={`Go to page ${i + 1}`}
				></button>
			))}
		</div>
	</div>
</section>

<style>
	.pagination-dot {
		width: 10px;
		height: 10px;
		border-radius: 50%;
		background-color: #d1d5db;
		transition: all 0.3s ease;
		cursor: pointer;
		border: none;
		padding: 0;
	}

	.pagination-dot:hover {
		background-color: #9ca3af;
	}

	.pagination-dot.active {
		background-color: #002147;
		width: 30px;
		border-radius: 5px;
	}
</style>

<script>
	const sliderTrack = document.getElementById('sliderTrack') as HTMLElement;
	const totalPages = parseInt(sliderTrack?.dataset.totalPages || '2', 10);
	let currentPage = 0;
	let autoPlayInterval: number | undefined;

	const prevBtn = document.getElementById('prevBtn') as HTMLButtonElement;
	const nextBtn = document.getElementById('nextBtn') as HTMLButtonElement;
	const dots = document.querySelectorAll('.pagination-dot');

	function updateSlider() {
		if (!sliderTrack) return;
		const translateX = -(currentPage * 100);
		sliderTrack.style.transform = `translateX(${translateX}%)`;

		// Update dots
		dots.forEach((dot, index) => {
			if (index === currentPage) {
				dot.classList.add('active');
			} else {
				dot.classList.remove('active');
			}
		});

		// Update buttons
		if (prevBtn) prevBtn.disabled = currentPage === 0;
		if (nextBtn) nextBtn.disabled = currentPage === totalPages - 1;
	}

	function goToPage(page: number) {
		if (page < 0 || page >= totalPages) return;
		currentPage = page;
		updateSlider();
		resetAutoPlay();
	}

	function nextPage() {
		if (currentPage < totalPages - 1) {
			currentPage++;
			updateSlider();
		}
	}

	function prevPage() {
		if (currentPage > 0) {
			currentPage--;
			updateSlider();
		}
	}

	function startAutoPlay() {
		autoPlayInterval = window.setInterval(() => {
			if (currentPage < totalPages - 1) {
				nextPage();
			} else {
				currentPage = 0;
				updateSlider();
			}
		}, 5000);
	}

	function stopAutoPlay() {
		if (autoPlayInterval !== undefined) {
			clearInterval(autoPlayInterval);
			autoPlayInterval = undefined;
		}
	}

	function resetAutoPlay() {
		stopAutoPlay();
		startAutoPlay();
	}

	// Event listeners
	prevBtn?.addEventListener('click', () => {
		prevPage();
		resetAutoPlay();
	});

	nextBtn?.addEventListener('click', () => {
		nextPage();
		resetAutoPlay();
	});

	dots.forEach((dot, index) => {
		dot.addEventListener('click', () => goToPage(index));
	});

	// Pause on hover
	const sliderContainer = sliderTrack?.parentElement;
	sliderContainer?.addEventListener('mouseenter', stopAutoPlay);
	sliderContainer?.addEventListener('mouseleave', startAutoPlay);

	// Initialize
	updateSlider();
	startAutoPlay();

	// Cleanup on page unload
	window.addEventListener('beforeunload', stopAutoPlay);
</script>
