---
 import { Image } from 'astro:assets';
import selfDefenseImage from '../../assets/images/selfDefense.png';
import cprImage from '../../assets/images/cpr.jpg';
import fireTrainingImage from '../../assets/images/fireTraining.png';
const trainingSlides = [
	{
		id: 1,
		title: 'การดับเพลิงเบื้องต้น',
		subtitle: 'Basic Fire Fighting Training',
		gradient: 'from-orange-500 to-red-600',
		icon: '🔥',
		image: fireTrainingImage
	},
	{
		id: 2,
		title: 'การปฐมพยาบาล',
		subtitle: 'First Aid & CPR Training',
		gradient: 'from-red-500 to-pink-600',
		icon: '🏥',
		image: cprImage
	},
	{
		id: 3,
		title: 'ศิลปะการป้องกันตัว',
		subtitle: 'Self Defense Techniques',
		gradient: 'from-blue-600 to-purple-600',
		icon: '🛡️',
		image: selfDefenseImage

	}
];
---

<!-- Training Section -->
<section class="w-full bg-slate-50 py-20 px-4 md:px-8">
	<div class="max-w-6xl mx-auto">

		<!-- Section Header -->
		<div class="text-center mb-12">
			<div class="inline-flex items-center justify-center p-2 bg-white rounded-full shadow-xs border border-slate-200 mb-4">
				<svg class="w-6 h-6 text-[#002147]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5 9 5c0 5.523-4.477 10-10 10s-10-4.477-10-10S6.477 4 12 4z"/>
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5 9 5c0 5.523-4.477 10-10 10s-10-4.477-10-10S6.477 4 12 4z"/>
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5 9 5c0 5.523-4.477 10-10 10s-10-4.477-10-10S6.477 4 12 4z"/>
				</svg>
			</div>
			<h2 class="text-3xl md:text-4xl font-bold text-[#002147] mb-2">
				หลักสูตรการฝึกอบรมที่เข้มข้น (Intensive Training)
			</h2>
			<p class="text-slate-600 text-lg font-medium">
				NSRS Standard <span class="text-amber-500 mx-2">•</span> ศูนย์ฝึก I.T.C. <span class="text-amber-500 mx-2">•</span> 40 ชั่วโมง
			</p>
		</div>

		<div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch">

			<!-- Left: Image Slider -->
			<div class="lg:col-span-5 flex flex-col h-full min-h-[320px] lg:min-h-[400px]">
				<div class="bg-slate-900 w-full h-full rounded-2xl relative overflow-hidden shadow-xl border border-slate-400/30 group" id="training-slider">

					<!-- SLIDES -->
					{trainingSlides.map((slide, index) => (
						<div
							data-slide={index}
							class={`training-slide absolute inset-0 transition-opacity duration-700 ease-in-out ${index === 0 ? 'opacity-100 z-10' : 'opacity-0 z-0'}`}
						>
							<Image
								src={slide.image}
								alt={slide.title}
								width={400}
								height={500}
								class={`w-full h-full object-cover  opacity-100`}
								style="object-position: center;"
							/>
							<!-- Gradient Overlay -->
							<div class={`absolute inset-0 bg-linear-to-br ${slide.gradient} opacity-40`}></div>
						</div>
					))}

					<!-- OVERLAY -->
					<div class="absolute inset-0 bg-linear-to-t from-black/90 via-black/20 to-transparent z-20 pointer-events-none"></div>

					<!-- CAPTION -->
					<div class="absolute bottom-6 left-6 right-6 z-30 transition-all duration-500" id="slide-caption">
						<div class="flex items-center gap-2 mb-2">
							<div class="w-2 h-2 rounded-full bg-red-500 animate-pulse"></div>
							<span class="text-amber-400 font-bold text-xs uppercase tracking-widest">Live Training</span>
						</div>
						<h3 class="text-white font-bold text-xl md:text-2xl drop-shadow-md" id="slide-title">
							{trainingSlides[0].title}
						</h3>
						<p class="text-slate-300 text-sm mt-1" id="slide-subtitle">
							{trainingSlides[0].subtitle}
						</p>
					</div>

					<!-- CONTROLS -->
					<button
						id="prev-slide"
						class="absolute left-4 top-1/2 -translate-y-1/2 z-30 bg-black/30 hover:bg-black/60 text-white p-2 rounded-full backdrop-blur-xs transition-all opacity-0 group-hover:opacity-100"
					>
						<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
						</svg>
					</button>
					<button
						id="next-slide"
						class="absolute right-4 top-1/2 -translate-y-1/2 z-30 bg-black/30 hover:bg-black/60 text-white p-2 rounded-full backdrop-blur-xs transition-all opacity-0 group-hover:opacity-100"
					>
						<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
						</svg>
					</button>

					<!-- INDICATORS -->
					<div class="absolute bottom-6 right-6 z-30 flex gap-2" id="slide-indicators">
						{trainingSlides.map((_, index) => (
							<button
								data-slide-index={index}
								class={`slide-indicator w-2 h-2 rounded-full transition-all duration-300 ${index === 0 ? 'bg-amber-500 w-6' : 'bg-white/50 hover:bg-white'}`}
							></button>
						))}
					</div>

				</div>
			</div>

			<!-- Right: Content Cards -->
			<div class="lg:col-span-7 flex flex-col gap-6">

				<!-- Card 1: Theory -->
				<div class="bg-white p-6 md:p-8 rounded-2xl shadow-lg border-l-4 border-amber-500 hover:shadow-xl transition-shadow">
					<div class="flex items-start gap-4 mb-4">
						<div class="p-3 bg-amber-100 rounded-lg text-amber-600">
							<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253"/>
							</svg>
						</div>
						<div>
							<h3 class="text-xl font-bold text-[#002147]">ภาคทฤษฎี & ระเบียบวินัย</h3>
							<p class="text-slate-500 text-sm">Theory & Discipline</p>
						</div>
					</div>
					<ul class="space-y-3 pl-2">
						<li class="flex items-center gap-3 text-slate-700">
							<div class="w-1.5 h-1.5 rounded-full bg-amber-500"></div>
							<span class="flex-1">กฎหมายจราจร (Traffic Laws)</span>
						</li>
						<li class="flex items-center gap-3 text-slate-700">
							<div class="w-1.5 h-1.5 rounded-full bg-amber-500"></div>
							<span class="flex-1">การเขียนรายงาน (Report Writing)</span>
						</li>
						<li class="flex items-center gap-3 text-slate-700">
							<div class="w-1.5 h-1.5 rounded-full bg-amber-500"></div>
							<span class="flex-1">มารยาทและการบริการ (Service Mind)</span>
						</li>
					</ul>
				</div>

				<!-- Card 2: Practical -->
				<div class="bg-[#002147] p-6 md:p-8 rounded-2xl shadow-lg border-l-4 border-red-500 text-white relative overflow-hidden hover:shadow-xl transition-shadow">
					<!-- Background Decor -->
					<div class="absolute right-0 top-0 opacity-10 transform translate-x-1/4 -translate-y-1/4">
						<svg class="w-40 h-40" fill="currentColor" viewBox="0 0 24 24">
							<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
						</svg>
					</div>

					<div class="flex items-start gap-4 mb-4 relative z-10">
						<div class="p-3 bg-red-500/20 rounded-lg text-red-400 border border-red-500/30">
							<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
							</svg>
						</div>
						<div>
							<h3 class="text-xl font-bold text-white">ภาคปฏิบัติ & เผชิญเหตุ</h3>
							<p class="text-slate-400 text-sm">Practical & Incident Response</p>
						</div>
					</div>
					<ul class="space-y-3 pl-2 relative z-10">
						<li class="flex items-center gap-3 text-white bg-white/10 p-2 rounded-lg -ml-2 pr-4 border border-white/5">
							<svg class="w-4 h-4 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"/>
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z"/>
							</svg>
							<span class="flex-1 font-bold">การดับเพลิงเบื้องต้น (Basic Fire Fighting)</span>
							<span class="text-[10px] bg-red-500 text-white px-2 py-0.5 rounded-sm uppercase tracking-wider">Highlight</span>
						</li>
						<li class="flex items-center gap-3 text-slate-300">
							<svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
							</svg>
							<span class="flex-1">การปฐมพยาบาล (First Aid / CPR)</span>
						</li>
						<li class="flex items-center gap-3 text-slate-300">
							<svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
							</svg>
							<span class="flex-1">ศิลปะการป้องกันตัว (Self Defense)</span>
						</li>
					</ul>
				</div>

			</div>
		</div>

		<!-- Footer Badge -->
		<div class="mt-8 flex justify-center">
			<div class="inline-flex items-center gap-2 bg-slate-200 text-slate-600 px-4 py-2 rounded-sm text-xs font-mono border border-slate-300">
				<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.707.293L15.414 5H17a2 2 0 012 2v10a2 2 0 01-2 2H5z"/>
				</svg>
				<span>ศูนย์ฝึกอบรมทะเบียนเลขที่ ก ๕๖๑๐๐๒๗</span>
			</div>
		</div>

	</div>
</section>

<script>
	// Training Slider Logic
	let currentSlide = 0;
	const totalSlides = 3;

	const prevBtn = document.getElementById('prev-slide');
	const nextBtn = document.getElementById('next-slide');
	const indicators = document.querySelectorAll('.slide-indicator');
	const slides = document.querySelectorAll('.training-slide');
	const slideTitle = document.getElementById('slide-title');
	const slideSubtitle = document.getElementById('slide-subtitle');

	const trainingData = [
		{ title: 'การดับเพลิงเบื้องต้น', subtitle: 'Basic Fire Fighting Training' },
		{ title: 'การปฐมพยาบาล', subtitle: 'First Aid & CPR Training' },
		{ title: 'ศิลปะการป้องกันตัว', subtitle: 'Self Defense Techniques' }
	];

	function updateSlide() {
		// Update slides
		slides.forEach((slide, index) => {
			if (index === currentSlide) {
				slide.classList.remove('opacity-0', 'z-0');
				slide.classList.add('opacity-100', 'z-10');
			} else {
				slide.classList.remove('opacity-100', 'z-10');
				slide.classList.add('opacity-0', 'z-0');
			}
		});

		// Update indicators
		indicators.forEach((indicator, index) => {
			if (index === currentSlide) {
				indicator.classList.remove('bg-white/50');
				indicator.classList.add('bg-amber-500', 'w-6');
			} else {
				indicator.classList.remove('bg-amber-500', 'w-6');
				indicator.classList.add('bg-white/50');
			}
		});

		// Update caption
		if (slideTitle && slideSubtitle) {
			slideTitle.textContent = trainingData[currentSlide].title;
			slideSubtitle.textContent = trainingData[currentSlide].subtitle;
		}
	}



	prevBtn?.addEventListener('click', () => {
		currentSlide--;
		if (currentSlide < 0) currentSlide = totalSlides - 1;
		updateSlide();
	});

	nextBtn?.addEventListener('click', () => {
		currentSlide++;
		if (currentSlide >= totalSlides) currentSlide = 0;
		updateSlide();
	});

	indicators.forEach((indicator, index) => {
		indicator.addEventListener('click', () => {
			currentSlide = index;
			updateSlide();
		});
	});

	// Auto-advance slides every 5 seconds
	setInterval(() => {
		currentSlide++;
		if (currentSlide >= totalSlides) currentSlide = 0;
		updateSlide();
	}, 5000);
</script>

<style>
	@keyframes animate-pulse-slow {
		0%, 100% { opacity: 1; }
		50% { opacity: 0.5; }
	}
	.animate-pulse-slow {
		animation: animate-pulse-slow 3s ease-in-out infinite;
	}
</style>
