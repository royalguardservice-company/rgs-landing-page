---
/**
 * TechShowcaseCard - Text content component for each feature
 * Displays the title, description, and optional feature list
 */
import type { TechShowcaseCardProps } from './types';

interface Props extends TechShowcaseCardProps {}

const { app, index, colors } = Astro.props;

const commandCenterFeatures = [
	{
		title: "Real-time Monitoring",
		desc: "รู้ความเคลื่อนไหวทันทีที่มีการสแกนจุดตรวจ",
		icon: "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
	},
	{
		title: "Digital Visitor Log",
		desc: "บันทึกภาพและทะเบียนรถอัตโนมัติ ค้นหาง่ายใน 3 วินาที",
		icon: "M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"
	},
	{
		title: "Incident Alerts",
		desc: "แจ้งเตือนเหตุด่วนพร้อมภาพถ่ายหลักฐานเข้าสู่ศูนย์กลาง",
		icon: "M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
	}
];
---

<div class="flex flex-col justify-center">
	{app.isCommandCenter ? (
		<fragment>
			<div class="inline-flex items-center px-3 py-1 rounded-full bg-white border border-blue-200 text-blue-800 text-xs font-bold tracking-wider uppercase mb-4 shadow-sm">
				<span class="w-2 h-2 rounded-full bg-blue-600 mr-2 animate-pulse"></span>
				Smart Security Ecosystem
			</div>

			<h2 class="text-3xl lg:text-4xl font-extrabold text-white leading-tight tracking-tight mb-4">
				ควบคุมทุกความปลอดภัย <br/>
				<span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-indigo-300">
					ผ่านศูนย์กลางข้อมูลอัจฉริยะ
				</span>
			</h2>

			<p class="text-gray-400 text-lg leading-relaxed border-l-4 border-blue-500/30 pl-4 mb-6">
				ติดตามสถานะการทำงาน ตรวจสอบผู้มาติดต่อ และดูรายงานสรุปได้แบบ Real-time ผ่าน Dashboard สำหรับผู้บริหาร หมดปัญหาการค้นหาข้อมูลจากสมุดบันทึกแบบเดิม
			</p>

			<div class="space-y-4">
				{commandCenterFeatures.map((item) => (
					<div class="group flex items-start gap-4 p-4 rounded-xl bg-white/5 border border-transparent hover:border-blue-500/30 hover:bg-white/10 transition-all duration-300">
						<div class="flex-shrink-0 w-12 h-12 rounded-xl bg-blue-600 group-hover:bg-blue-500 flex items-center justify-center text-white shadow-md shadow-blue-600/20 transition-colors">
							<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon} />
							</svg>
						</div>
						<div>
							<h4 class="font-bold text-white text-base">{item.title}</h4>
							<p class="text-gray-400 text-sm mt-1">{item.desc}</p>
						</div>
					</div>
				))}
			</div>
		</fragment>
	) : (
		<fragment>
			<div class="flex items-center gap-2 mb-3">
				<span class={`px-3 py-1 rounded-full text-xs font-medium ${colors.badge}`}>
					Step 0{index + 1}
				</span>
				<span class="text-gray-500 text-sm">{app.stage}</span>
			</div>

			<h3 class={`text-2xl lg:text-3xl font-bold text-white mb-4 ${colors.title}`}>
				{app.thaiTitle}
			</h3>

			<p class="text-gray-400 text-lg leading-relaxed">
				{app.subtitle}
			</p>
		</fragment>
	)}
</div>
