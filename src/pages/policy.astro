---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

const contactInfo = {
	companyName: 'บริษัท รักษาความปลอดภัย รอยัลการ์ด เซอร์วิสเซส จำกัด',
	address: '300/44 โครงการพรีเมียมเพลส',
	street: 'ถนนนวมินทร์ แขวงนวมินทร์ เขตบึงกุ่ม',
	city: 'กรุงเทพมหานคร 10240',
	phone: '02-379-1713-4',
	hotline1: '096-564-5493 (คุณเอก)',
	hotline2: '065-294-1962 (คุณแคนดี้)',
	email: 'royalguardservices2016@gmail.com',
	lineId: '0816968904',
	license: 'ตภ.2600068'
};
---

<Layout title="นโยบายความเป็นส่วนตัว - RGS">
	<main>
		<!-- Page Header -->
		<section class="bg-navy-950 py-16 px-4 relative overflow-hidden">
			<div class="absolute inset-0 opacity-10">
				<div class="absolute top-10 right-10 w-64 h-64 bg-amber-400 rounded-full blur-3xl"></div>
				<div class="absolute bottom-10 left-10 w-80 h-80 bg-blue-900 rounded-full blur-3xl"></div>
			</div>
			<div class="container-custom relative z-10">
				<div class="flex items-center gap-4 mb-4">
					<img src="/logo.png" alt="RGS Logo" class="h-16 md:h-20 w-auto" />
					<div>
						<p class="text-amber-400 text-sm font-medium mb-1">Privacy Policy</p>
						<h1 class="text-3xl md:text-4xl font-bold text-white">นโยบายและระเบียบปฏิบัติ<br />การคุ้มครองข้อมูลส่วนบุคคล</h1>
					</div>
				</div>
			</div>
		</section>

		<!-- Main Content -->
		<section class="bg-navy-900 py-12 px-4">
			<div class="container-custom">
				<div class="bg-white rounded-lg shadow-2xl p-6 md:p-10 space-y-8 text-gray-700 leading-relaxed">

					<!-- Introduction -->
					<div class="border-l-4 border-amber-500 pl-4 bg-amber-50 py-3 rounded-r">
						<p class="text-sm text-gray-700">
							บริษัท รอยัล การ์ด เซคิวริตี้ (รวมเรียกว่า "บริษัท") เคารพสิทธิความเป็นส่วนตัวของคู่ค้า คู่สัญญา พนักงานและหรือผู้มีส่วนเกี่ยวข้องกับธุรกิจของบริษัท ฯ (รวมเรียกว่า "ท่าน") เพื่อให้เกิดความมั่นใจว่า ท่าน จะได้รับความคุ้มครองสิทธิอย่างครบถ้วนตามกฎหมายพระราชบัญญัติคุ้มครองข้อมูลส่วนบุคคล พ.ศ 2562 จึงได้จัดทำนโยบายและระเบียบปฏิบัติการคุ้มครองข้อมูลส่วนบุคคลไว้ ดังต่อไปนี้
						</p>
					</div>

					<!-- Section 1: Purpose -->
					<div>
						<h2 class="text-xl font-bold text-[#002147] mb-4 border-b-2 border-amber-500 pb-2 flex items-center gap-2">
							<span class="w-8 h-8 bg-amber-500 text-white rounded-full flex items-center justify-center text-sm">1</span>
							วัตถุประสงค์การเก็บรวบรวม ใช้หรือเปิดเผยข้อมูลส่วนบุคคล
						</h2>
						<p class="mb-4 text-sm">บริษัทฯ เก็บรวบรวม ใช้ หรือเปิดเผยข้อมูลส่วนบุคคลของท่าน เพื่อวัตถุประสงค์หลายประการภายใต้กฎหมาย</p>

						<div class="space-y-4 ml-4">
							<div class="bg-gray-50 p-4 rounded-lg">
								<h3 class="font-semibold text-[#002147] mb-2 ">เพื่อการปฏิบัติตามสัญญา</h3>
								<p class="text-sm">เพื่อการพิจารณาคัดเลือกคุณสมบัติก่อนการเข้าทำสัญญา การทำสัญญาระหว่างกัน การติดต่อประสานงานเกี่ยวกับการปฏิบัติตามสัญญา ตลอดจนการชำระเงินตามสัญญา และการดำเนินการชำระเงินผ่าน Platform ของผู้ให้บริการของ บริษัทฯ</p>
							</div>

							<div class="bg-gray-50 p-4 rounded-lg">
								<h3 class="font-semibold text-[#002147] mb-2 ">เพื่อการปฏิบัติตามกฎหมาย</h3>
								<p class="text-sm">เพื่อความจำเป็นในการใช้สิทธิเรียกร้องตามกฎหมาย เพื่อเป็นหลักฐานในการยกขึ้นเป็นข้อต่อสู้เรียกร้องสิทธิตามกฎหมาย การปฏิบัติตามคำสั่งของศาลหรือตามคำสั่งของหน่วยงานราชการที่มีอำนาจตามกฎหมาย</p>
							</div>

							<div class="bg-gray-50 p-4 rounded-lg">
								<h3 class="font-semibold text-[#002147] mb-2 ">เพื่อประโยชน์โดยชอบด้วยกฎหมาย</h3>
								<p class="text-sm mb-2">โดยคำนึงถึงความเหมาะสมและความคาดหมายของท่าน เพื่อวัตถุประสงค์ดังต่อไปนี้:</p>
								<ul class="list-disc list-inside text-sm space-y-1 ml-4">
									<li>เพื่อวัตถุประสงค์ในการตรวจสอบและยืนยันตัวตนเกี่ยวกับการเข้าทำธุรกรรม</li>
									<li>เพื่อการตรวจสอบและการบริหารความเสี่ยง ตลอดจนการป้องกันการกระทำผิด</li>
									<li>เพื่อการวิเคราะห์ ประเมิน ปรับปรุง และวางแผนทางธุรกิจ</li>
									<li>เพื่อรักษาความปลอดภัยภายในบริเวณอาคารหรือสถานที่จากการบันทึกภาพด้วยระบบกล้องวงจรปิด (CCTV)</li>
								</ul>
							</div>
						</div>
					</div>

					<!-- Section 2: Personnel -->
					<div>
						<h2 class="text-xl font-bold text-[#002147] mb-4 border-b-2 border-amber-500 pb-2 flex items-center gap-2">
							<span class="w-8 h-8 bg-amber-500 text-white rounded-full flex items-center justify-center text-sm">2</span>
							ผู้มีหน้าที่เกี่ยวข้องกับการคุ้มครองข้อมูลส่วนบุคคล
						</h2>
						<p class="text-sm mb-4">เพื่อให้นโยบายและระเบียบปฏิบัติการคุ้มครองข้อมูลส่วนบุคคลดำเนินไปอย่างต่อเนื่องและมีประสิทธิภาพ บริษัท ฯ จึงแต่งตั้งบุคคลผู้มีตำแหน่ง ดังต่อไปนี้</p>
						<ul class="list-disc list-inside text-sm space-y-2 ml-4 bg-gray-50 p-4 rounded-lg">
							<li>กรรมการผู้จัดการเป็นผู้ควบคุมข้อมูลส่วนบุคคลในนามของบริษัท</li>
							<li>ผู้จัดการทั่วไปเป็นตัวแทนฝ่ายบริหารในระบบคุ้มครองข้อมูลส่วนบุคคล</li>
							<li>ผู้จัดการฝ่ายการตลาดเป็นผู้ควบคุมข้อมูลส่วนบุคคลของคู่ค้าและคู่สัญญา</li>
							<li>เจ้าหน้าที่ธุรการฝ่ายการตลาดเป็นผู้ประมวลผลและจัดเก็บข้อมูลส่วนบุคคล</li>
							<li>เจ้าหน้าที่ฝ่ายเทคโนโลยีสารสนเทศเป็นผู้คุ้มครองข้อมูลในสื่ออิเล็กทรอนิกส์</li>
						</ul>
					</div>

					<!-- Section 3: Data Types -->
					<div>
						<h2 class="text-xl font-bold text-[#002147] mb-4 border-b-2 border-amber-500 pb-2 flex items-center gap-2">
							<span class="w-8 h-8 bg-amber-500 text-white rounded-full flex items-center justify-center text-sm">3</span>
							ประเภทข้อมูลส่วนบุคคล
						</h2>
						<div class="grid gap-3 ml-4 text-sm">
							<div class="flex gap-3 items-start bg-blue-50 p-3 rounded">
								<span class="text-blue-900 font-bold">3.1</span>
								<div><strong class="text-blue-900">ข้อมูลส่วนตัว:</strong> ชื่อ นามสกุล อายุ วันเดือนปีเกิด เลขประจำตัวประชาชน เลขหนังสือเดินทาง เชื้อชาติ สัญชาติ ศาสนา ตำแหน่ง ประสบการณ์การทำงาน ความเชี่ยวชาญ เลขที่ผู้เสียภาษี</div>
							</div>
							<div class="flex gap-3 items-start bg-green-50 p-3 rounded">
								<span class="text-green-900 font-bold">3.2</span>
								<div><strong class="text-green-900">ข้อมูลการติดต่อ:</strong> ที่อยู่อาศัย สถานที่ทำงาน หมายเลขโทรศัพท์ อีเมล ไอดีไลน์</div>
							</div>
							<div class="flex gap-3 items-start bg-purple-50 p-3 rounded">
								<span class="text-purple-900 font-bold">3.3</span>
								<div><strong class="text-purple-900">ข้อมูลทางการเงิน:</strong> หมายเลขบัญชีธนาคาร</div>
							</div>
							<div class="flex gap-3 items-start bg-amber-50 p-3 rounded">
								<span class="text-amber-900 font-bold">3.4</span>
								<div><strong class="text-amber-900">ข้อมูลอื่น ๆ:</strong> การบันทึกภาพจากกล้องวงจรปิด การบันทึกภาพและเสียงจากการประชุม และข้อมูลจากการใช้ระบบสารสนเทศ</div>
							</div>
							<div class="flex gap-3 items-start bg-red-50 p-3 rounded">
								<span class="text-red-900 font-bold">3.5-3.8</span>
								<div><strong class="text-red-900">ข้อมูลเพิ่มเติม:</strong> ข้อมูลจากการลงนามในสัญญา, ข้อมูลจากแบบสำรวจ, ข้อมูลส่วนบุคคลที่เข้าใช้งาน Platforms ต่าง ๆ หรือ เว็บไซต์, ข้อมูลการใช้คุกกี้</div>
							</div>
						</div>
					</div>

					<!-- Section 4: Retention Period -->
					<div>
						<h2 class="text-xl font-bold text-[#002147] mb-4 border-b-2 border-amber-500 pb-2 flex items-center gap-2">
							<span class="w-8 h-8 bg-amber-500 text-white rounded-full flex items-center justify-center text-sm">4</span>
							ระยะเวลาในการจัดเก็บข้อมูลส่วนบุคคลของท่าน
						</h2>
						<div class="bg-blue-50 border-l-4 border-blue-500 p-4 rounded">
							<p class="text-sm mb-3">บริษัท ฯ จะเก็บรักษาข้อมูลส่วนบุคคลของท่าน (ที่ไม่เกี่ยวเนื่องกับสัญญาจ้างงานบริการ) ไว้ในระยะเวลาเท่าที่ข้อมูลนั้นยังมีความจำเป็นตามวัตถุประสงค์ในการเก็บรวบรวมเท่านั้น</p>
							<p class="text-sm"><strong>เอกสารสัญญาจ้างงานบริการ:</strong> จะเก็บรวบรวมข้อมูลของท่านเป็นระยะเวลา <span class="text-amber-600 font-bold text-lg">10 ปี</span> นับตั้งแต่วันที่ยกเลิกสัญญา</p>
						</div>
					</div>

					<!-- Section 5: Disclosure -->
					<div>
						<h2 class="text-xl font-bold text-[#002147] mb-4 border-b-2 border-amber-500 pb-2 flex items-center gap-2">
							<span class="w-8 h-8 bg-amber-500 text-white rounded-full flex items-center justify-center text-sm">5</span>
							การเปิดเผยข้อมูลส่วนบุคคลของท่าน
						</h2>
						<div class="bg-yellow-50 border border-yellow-200 p-4 rounded text-sm">
							<p class="mb-2"><strong class="text-yellow-800">หลักการ:</strong> การเปิดเผยข้อมูลส่วนบุคคลของท่านต่อบุคคลภายนอก ต้องได้รับการยินยอมจากท่าน</p>
							<p>และบริษัท ฯ จะดำเนินการภายใต้กรอบของกฎหมาย และเกี่ยวเนื่องกับกิจกรรมของบริษัท ฯ เท่านั้น</p>
						</div>
					</div>

					<!-- Section 6: Data Security -->
					<div>
						<h2 class="text-xl font-bold text-[#002147] mb-4 border-b-2 border-amber-500 pb-2 flex items-center gap-2">
							<span class="w-8 h-8 bg-amber-500 text-white rounded-full flex items-center justify-center text-sm">6</span>
							ความปลอดภัยของข้อมูลส่วนบุคคลของท่าน
						</h2>
						<p class="text-sm mb-3">บริษัท ฯ จัดให้มีวิธีการจัดเก็บข้อมูลส่วนบุคคลเพื่อความปลอดภัย ดังนี้</p>
						<ul class="list-disc list-inside text-sm space-y-2 ml-4">
							<li><strong class="text-[#002147]">วิธีการเก็บและสถานที่เก็บข้อมูล</strong> ในรูปแบบสื่ออิเล็กทรอนิกส์ และหรือ ที่เป็นเอกสาร</li>
							<li>กำหนด Password หรือผู้รับผิดชอบการจัดเก็บ การใช้ การเปิดเผยที่ชัดเจนเฉพาะคน</li>
							<li>กำหนดให้มีการตรวจสอบเป็นระยะ และให้มีการทบทวนระบบอย่างน้อย <strong class="text-amber-600">ปีละ 1 ครั้ง</strong></li>
						</ul>
					</div>

					<!-- Section 7: Data Owner Rights -->
					<div>
						<h2 class="text-xl font-bold text-[#002147] mb-4 border-b-2 border-amber-500 pb-2 flex items-center gap-2">
							<span class="w-8 h-8 bg-amber-500 text-white rounded-full flex items-center justify-center text-sm">7</span>
							สิทธิของเจ้าของข้อมูลส่วนบุคคล
						</h2>
						<p class="text-sm mb-3">บริษัท ฯ ให้ความสำคัญและเคารพสิทธิ เสรีภาพของเจ้าของข้อมูลอย่างสูงสุด และจัดให้เจ้าของข้อมูลมีสิทธิ ดังต่อไปนี้</p>
						<div class="grid grid-cols-1 md:grid-cols-2 gap-3">
							<div class="bg-green-50 p-3 rounded border-l-4 border-green-500 text-sm">ขอตรวจสอบวิธีการจัดเก็บ การใช้ การเปิดเผยข้อมูลได้</div>
							<div class="bg-green-50 p-3 rounded border-l-4 border-green-500 text-sm">ขอคัดค้าน ขอระงับการใช้ได้</div>
							<div class="bg-green-50 p-3 rounded border-l-4 border-green-500 text-sm">ขอถอนความยินยอมได้</div>
							<div class="bg-green-50 p-3 rounded border-l-4 border-green-500 text-sm">ขอให้ลบออกจากการเก็บ การใช้ การเปิดเผยได้</div>
							<div class="bg-green-50 p-3 rounded border-l-4 border-green-500 text-sm">ขอให้เปลี่ยนแปลงแก้ไขข้อมูลให้ถูกต้องได้</div>
							<div class="bg-green-50 p-3 rounded border-l-4 border-green-500 text-sm">คู่ค้าและหรือคู่สัญญา ขอใช้สิทธิข้างต้น หรือร้องเรียน</div>
						</div>
					</div>

					<!-- Section 8: Data Owner Duties -->
					<div>
						<h2 class="text-xl font-bold text-[#002147] mb-4 border-b-2 border-amber-500 pb-2 flex items-center gap-2">
							<span class="w-8 h-8 bg-amber-500 text-white rounded-full flex items-center justify-center text-sm">8</span>
							หน้าที่ของเจ้าของข้อมูล
						</h2>
						<ul class="list-disc list-inside text-sm space-y-2 ml-4 bg-gray-50 p-4 rounded-lg">
							<li>นำส่งข้อมูลส่วนบุคคลของตนให้ผู้มีหน้าที่เกี่ยวข้องตามกำหนดเวลา</li>
							<li>ถ้ามีการเปลี่ยนแปลงข้อมูลส่วนบุคคล ให้แจ้งผู้เกี่ยวข้องให้ทราบทันที</li>
							<li>ต้องใช้ข้อมูลส่วนบุคคลของคนอื่นตามหน้าที่โดยสุจริต ห้ามนำไปหาประโยชน์ส่วนตัว</li>
							<li>หากพบเหตุผิดปกติ ให้แจ้งบริษัท ฯ ทราบทันทีเพื่อระงับได้ทันเหตุการณ์</li>
						</ul>
					</div>

					<!-- Section 9: Penalties -->
					<div>
						<h2 class="text-xl font-bold text-[#002147] mb-4 border-b-2 border-amber-500 pb-2 flex items-center gap-2">
							<span class="w-8 h-8 bg-amber-500 text-white rounded-full flex items-center justify-center text-sm">9</span>
							บทลงโทษผู้ฝ่าฝืน
						</h2>
						<div class="bg-red-50 border border-red-200 p-4 rounded">
							<p class="text-sm mb-3 font-semibold text-red-800">พนักงาน คู่ค้า คู่สัญญา ผู้มีส่วนเกี่ยวข้อง ที่นำข้อมูลส่วนบุคคลที่บริษัท ฯ คุ้มครองไว้:</p>
							<ul class="list-disc list-inside text-sm space-y-2 ml-4 text-red-900">
								<li>ไปใช้เปิดเผย หาประโยชน์นอกจากวัตถุประสงค์ที่ผู้ขอใช้ข้อมูลยินยอม</li>
